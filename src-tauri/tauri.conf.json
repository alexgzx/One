{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:20127",
    "distDir": "../out"
  },
  "package": {
    "productName": "One",
    "version": "0.5.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "dmg"],
      "identifier": "com.one.desktop",
      "icon": [
        "../build/icon-32x32.png",
        "../build/icon-128x128.png",
        "../build/icon-256x256.png",
        "../build/icon-512x512.png",
        "../build/icon.ico",
        "../build/icon.icns"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        }
      },
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "11.0",
        "exceptionDomain": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src *;"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "One",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "systemTray": {
      "iconPath": "../build/icon.ico",
      "iconAsTemplate": true,
      "tooltip": "One"
    }
  }
}
