# ============================================================
# Dependencies
# ============================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# Build output
# ============================================================
.next/
.next-cli-build/
/out/
/build
cli/.build-home/
cli/app/
product/

