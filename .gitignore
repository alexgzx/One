# ============================================================
release/
*.exe
*.dmg
*.zip
*.tgz
*.tar.gz

# ============================================================
# Editor / IDE
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# Logs & debug
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================================
# Environment & secrets
# ============================================================
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# ============================================================
# Runtime data (local DB, machine-id, etc.)
# ============================================================
data/
logs/

# ============================================================
# TypeScript
# ============================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================
# Misc project-specific
# ============================================================
.bin/*
.cursor/*
source/*
test/*
open-sse/test/*
docs/*
